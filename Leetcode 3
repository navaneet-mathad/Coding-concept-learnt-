class Solution:
    def lengthOfLongestSubstring(self, s: str) -> int:
        charSet = set()
        l=0
        res = 0
        for r in range(len(s)):      //r is also the right pointer 
            while s[r] in charSet:    //empty set to handle duplicates
                charSet.remove(s[l])  //if yes, then remove
                l+=1                  //then update left pointer l
            charSet.add(s[r])          //finally add it to the charset 
            res = max(res,r-l+1)
        return res

