since u are using reshape function, the rows and columns in the o/p and i/p must be same and cannot be destroyed.
import numpy as np
class Solution:
    def matrixReshape(self, mat: List[List[int]], r: int, c: int) -> List[List[int]]:
        arr = np.array(mat)
        if arr.size != r*c:  #this line explains the constraint above. 
            return mat       #return the original matrix
        return arr.reshape(r,c).tolist()
